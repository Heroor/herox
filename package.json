{
  "name": "herox-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "NODE_OPTIONS=--conditions=development tsx ./packages/cli/src/index.ts",
    "debug": "tsx ./packages/cli/src/index.ts",
    "build": "pnpm -r --sort run build",
    "changeset": "changeset",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "pack:dry": "pnpm --filter @heroor/x pack --dry-run",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.8"
  }
}
