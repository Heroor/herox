{
  "name": "@heroor/x",
  "version": "0.1.0",
  "description": "Herox Agent CLI for OpenAI-compatible AI models and local developer workflows.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "herox": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/*.tsbuildinfo",
    "!dist/**/*.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "tsdown": {
    "fixedExtension": false,
    "dts": false,
    "deps": {
      "alwaysBundle": [
        "@heroor/x-core",
        "@heroor/x-providers",
        "@heroor/x-shared",
        "@heroor/x-tools"
      ]
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --target node20 --platform node --clean",
    "pack:dry": "pnpm pack --dry-run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@heroor/x-core": "workspace:*",
    "@heroor/x-shared": "workspace:*"
  }
}
